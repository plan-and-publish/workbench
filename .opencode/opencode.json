{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "ck": {
            "type": "local",
            "enabled": true,
            "command": [
                "ck",
                "--serve"
            ]
        },
        "linear": {
            "type": "remote",
            "url": "https://mcp.linear.app/mcp",
            "enabled": true 
        }
    },
    "agent": {
        "general": {
            "tools": {
                "ck_semantic_search": true,
                "ck_hybrid_search": true
            }
        },
        "explore": {
            "tools": {
                "ck_semantic_search": true,
                "ck_hybrid_search": true
            }
        }
    }
}