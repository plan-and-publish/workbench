{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "ck": {
            "type": "local",
            "enabled": true,
            "command": [
                "ck",
                "--serve"
            ]
        },
        "linear": {
            "type": "remote",
            "url": "https://mcp.linear.app/mcp",
            "enabled": true
        }
    },
    "provider": {
        "openai": {
            "options": {
                "timeout": 1800000
            }
        },
        "zai-coding-plan": {
            "options": {
                "timeout": 1800000
            }
        }
    }
}
